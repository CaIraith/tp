<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS" vgap="5" hgap="10" minHeight="30" prefHeight="30" maxHeight="30">
    <padding>
      <Insets bottom="3" top="3" />
    </padding>
    <columnConstraints>
      <ColumnConstraints minWidth="50" prefWidth="50" maxWidth="50" hgrow="NEVER" />
      <ColumnConstraints minWidth="100" prefWidth="150" hgrow="ALWAYS" />
      <ColumnConstraints minWidth="100" prefWidth="150" hgrow="ALWAYS" />
      <ColumnConstraints minWidth="100" prefWidth="150" hgrow="ALWAYS" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="130" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>
      <FlowPane fx:id="tags" />
      <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address" />
      <Label fx:id="postalCode" styleClass="cell_small_label" text="\$postalCode" />
      <Label fx:id="email" styleClass="cell_small_label" text="\$email" />
    </VBox>

    <Label fx:id="id" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="cell_small_label" />

    <Label fx:id="name" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="cell_small_label" />

    <StackPane GridPane.rowIndex="0" GridPane.columnIndex="2"
               prefWidth="300" maxWidth="300" prefHeight="30">
      <FlowPane fx:id="tags_card"
                hgap="5"
                orientation="HORIZONTAL"
                prefHeight="30"
                minHeight="30"
                style="-fx-padding: 4 0 0 5;" />
    </StackPane>

    <Label fx:id="address" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="cell_small_label" />
  </GridPane>
</HBox>
